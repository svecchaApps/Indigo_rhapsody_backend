  "notes": {
    "userId": "Must be a valid MongoDB ObjectId of an existing User",
    "cartId": "Must be a valid MongoDB ObjectId of an existing Cart that belongs to the userId",
    "paymentMethod": "Case-insensitive. Common values: 'cod', 'Razorpay', 'Phonepe', 'stripe', 'paypal'",
    "address": {
      "street": "Required - Street address",
      "city": "Required - City name",
      "state": "Required - State name",
      "pincode": "Required - 6-digit PIN code",
      "phoneNumber": "Optional - Will fallback to user's phoneNumber if not provided"
