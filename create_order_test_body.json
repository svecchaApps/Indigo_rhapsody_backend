{
  "description": "Test body examples for creating an order via POST /order",
  "required_fields": [
    "userId",
    "cartId",
    "paymentMethod",
    "address"
  ],
  "address_required_fields": [
    "street",
    "city",
    "state",
    "pincode"
  ],
  "examples": {
